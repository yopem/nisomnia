{
  "name": "@nisomnia/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "analyze": "cross-env ANALYZE=true next build",
    "build": "pnpm with-env next build",
    "clean": "git clean -xdf .next .turbo node_modules",
    "dev": "pnpm with-env next dev",
    "dev:turbo": "pnpm with-env next dev --turbo",
    "format": "prettier --check \"**/*.{js,cjs,mjs,ts,tsx,md,json}\"",
    "lint": "dotenv -v SKIP_ENV_VALIDATION=1 next lint",
    "lint:fix": "pnpm lint --fix",
    "start": "pnpm with-env next start",
    "type-check": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.449.0",
    "@ducanh2912/next-pwa": "^9.7.2",
    "@nisomnia/api": "workspace:*",
    "@nisomnia/auth": "workspace:*",
    "@nisomnia/db": "workspace:*",
    "@nisomnia/editor": "workspace:*",
    "@nisomnia/ui": "workspace:*",
    "@nisomnia/utils": "workspace:*",
    "@t3-oss/env-nextjs": "^0.7.1",
    "@tanstack/react-query": "^4.36.1",
    "@trpc/client": "^10.43.3",
    "@trpc/next": "^10.43.3",
    "@trpc/react-query": "^10.43.3",
    "axios": "^1.6.1",
    "million": "2.6.4",
    "next-intl": "^2.22.1",
    "next-seo": "^6.4.0",
    "next-themes": "^0.2.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.48.2",
    "react-image-file-resizer": "^0.4.8",
    "react-intersection-observer": "^9.5.3",
    "react-lite-youtube-embed": "^2.3.52",
    "react-tweet-embed": "^2.0.0",
    "react-wrap-balancer": "^1.1.0",
    "rehype-parse": "^9.0.0",
    "rehype-react": "^8.0.0",
    "sharp": "^0.32.6",
    "superjson": "2.2.1",
    "swr": "^2.2.4",
    "unified": "^11.0.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.0.2",
    "@nisomnia/eslint-config": "workspace:*",
    "@nisomnia/prettier-config": "workspace:*",
    "@nisomnia/tailwind-config": "workspace:*",
    "@nisomnia/tsconfig": "workspace:*",
    "@tanstack/react-query-devtools": "^4.36.1",
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "autoprefixer": "^10.4.16",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.3.0",
    "eslint": "^8.53.0",
    "prettier": "^3.0.3",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2",
    "webpack": "^5.89.0"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@nisomnia/eslint-config/base",
      "@nisomnia/eslint-config/nextjs",
      "@nisomnia/eslint-config/react"
    ]
  },
  "prettier": "@nisomnia/prettier-config",
  "browser": {
    "fs": false,
    "os": false,
    "path": false
  }
}
